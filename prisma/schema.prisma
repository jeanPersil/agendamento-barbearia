generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  phone    String
  password String
  role     Int    @default(0) // 0: Client, 1: Admin

  appointments Appointment[]

  @@map("users")
}

model Service {
  id              Int    @id @default(autoincrement())
  name            String @unique
  price           Float
  durationMinutes Int

  appointments Appointment[]

  @@map("services")
}

model Schedule {
  id        Int     @id @default(autoincrement())
  dayOfWeek Int // 0 (Sun) to 6 (Sat)
  startTime String // "08:00"
  endTime   String // "19:00"
  isActive  Boolean @default(true)

  @@map("schedules")
}

model AppointmentStatus {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  appointments Appointment[]

  @@map("appointment_statuses")
}

model Appointment {
  id              Int      @id @default(autoincrement())
  clientId        Int
  serviceId       Int
  statusId        Int      @default(1)
  appointmentDate DateTime
  startTime       String
  endTime         String
  createdAt       DateTime @default(now())

  client   User              @relation(fields: [clientId], references: [id])
  service  Service           @relation(fields: [serviceId], references: [id])
  status   AppointmentStatus @relation(fields: [statusId], references: [id])
  payments Payment[]

  @@map("appointments")
}

model PaymentMethod {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  payments Payment[]

  @@map("payment_methods")
}

model Payment {
  id            Int       @id @default(autoincrement())
  appointmentId Int
  methodId      Int
  amount        Float
  paidAt        DateTime? @default(now())

  appointment Appointment   @relation(fields: [appointmentId], references: [id])
  method      PaymentMethod @relation(fields: [methodId], references: [id])

  @@map("payments")
}
