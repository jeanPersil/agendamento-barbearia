generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

//////////////////////
// ENUMS
//////////////////////

model Usuario {
  id       Int    @id @default(autoincrement())
  nome     String
  email    String @unique
  telefone    String
  senha String
  role     Int    @default(0) // 0: Cliente, 1: Admin

  agendamentos Agendamento[]

  @@map("usuarios")
}

model Servico {
  id         Int    @id @default(autoincrement())
  nome       String @unique
  preco      Float
  duracaoMin Int

  agendamentos Agendamento[]

  @@map("servicos")
}

model Expediente {
  id         Int     @id @default(autoincrement())
  diaSemana  Int // 0 (Dom) a 6 (Sab)
  horaInicio String // "08:00"
  horaFim    String // "19:00"
  ativo      Boolean @default(true)

  @@map("expediente")
}

model StatusAgendamento {
  id           Int           @id @default(autoincrement())
  nome         String        @unique
  agendamentos Agendamento[]

  @@map("status_agendamento")
}

model Agendamento {
  id              Int      @id @default(autoincrement())
  clienteId       Int
  servicoId       Int
  statusId        Int      @default(1)
  dataServico     DateTime
  horarioDeInicio String
  horarioDeFim    String
  createdAt       DateTime @default(now())

  cliente    Usuario           @relation(fields: [clienteId], references: [id])
  servico    Servico           @relation(fields: [servicoId], references: [id])
  status     StatusAgendamento @relation(fields: [statusId], references: [id])
  pagamentos Pagamento[]

  @@map("agendamentos")
}

model MetodoPagamento {
  id         Int         @id @default(autoincrement())
  nome       String      @unique
  pagamentos Pagamento[]

  @@map("metodos_pagamento")
}

model Pagamento {
  id            Int       @id @default(autoincrement())
  agendamentoId Int
  metodoId      Int
  valor         Float
  pagoEm        DateTime? @default(now())

  agendamento Agendamento     @relation(fields: [agendamentoId], references: [id])
  metodo      MetodoPagamento @relation(fields: [metodoId], references: [id])

  @@map("pagamentos")
}
